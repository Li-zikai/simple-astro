---
import '../styles/global.css';
import {
  defaultFilingVariant,
  filingVariantAttribute,
  gamemacCnFilingVariant,
  gamemacCnHosts,
} from '../lib/filingVariants.js';

interface Props {
  title?: string;
  lang?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
}

const {
  title = 'GameHub',
  lang = 'en',
  description = 'Play Windows games on Mac with Apple Silicon. GameHub lets you run AAA Windows titles on your Mac seamlessly.',
  keywords = 'GameHub, Windows games on Mac, Mac gaming, Apple Silicon gaming, play Windows games, Mac M-series gaming, Steam on Mac',
  ogImage = '/favicon.png',
} = Astro.props;

const siteUrl = 'https://www.gamemac.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;

const alternateLang = lang === 'en' ? 'zh-CN' : 'en';
const alternatePath = lang === 'en' ? '/zh-cn' : '/en';

// Preload the hero LCP image
const heroImage = lang === 'en' || lang === 'en-US'
  ? '/MacBook-air2.png'
  : '/MacBook-air3.png';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'GameHub',
  applicationCategory: 'GameApplication',
  operatingSystem: 'macOS',
  description,
  url: siteUrl,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};

const filingVariantInitScript = `(function(){var host=(window.location.hostname||"").toLowerCase();var variant=${JSON.stringify(defaultFilingVariant)};var cnHosts=${JSON.stringify(gamemacCnHosts)};if(cnHosts.indexOf(host)!==-1){variant=${JSON.stringify(gamemacCnFilingVariant)};}document.documentElement.setAttribute(${JSON.stringify(filingVariantAttribute)},variant);}());`;
---

<!doctype html>
<html lang={lang} data-filing-variant={defaultFilingVariant}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="RQNkdkjXyhX1qruzwREJHOrVoUh863_UshatzdbYoy8" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png?v=2" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link rel="shortcut icon" href="/favicon.ico?v=2" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload LCP hero image -->
    <link rel="preload" as="image" href={heroImage} fetchpriority="high" />

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="theme-color" content="#030014" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="GameHub" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang for multi-language -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={`${siteUrl}${alternatePath}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en`} />

    <!-- Open Graph / Facebook / Discord / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="GameHub" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'zh_CN'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'zh_CN' : 'en_US'} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script is:inline set:html={filingVariantInitScript}></script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script is:inline>
      (function() {
        function applyScale() {
          var app = document.querySelector('.app');
          if (!app) return;
          var scale = Math.min(1, window.innerWidth / 1440);
          if (scale < 1) {
            app.style.transform = 'scale(' + scale + ')';
            app.style.transformOrigin = 'top left';
            app.style.marginBottom = -(app.scrollHeight * (1 - scale)) + 'px';
          } else {
            app.style.transform = '';
            app.style.transformOrigin = '';
            app.style.marginBottom = '';
          }
        }
        applyScale();
        window.addEventListener('resize', applyScale);
      })();
    </script>
    <script>
      function initReveal() {
        const textSelectors = [
          '.hero-title', '.hero-headline',
          '.hero-subtitle', '.hero-caption',
          '.showcase-title', '.showcase-subtitle',
          '.steam-management-title', '.steam-management-subtitle',
          '.steam-data-text',
          '.compat-title', '.compat-desc', '.compat-card-title', '.compat-card-desc',
          '.survey-title', '.survey-desc',
          '.faq-title', '.faq-subtitle', '.faq-bottom-logo-text',
        ];
        const cardSelectors = [
          '.showcase-box-anim',
        ];
        const allSelectors = [...textSelectors, ...cardSelectors];
        const els = document.querySelectorAll(allSelectors.join(','));
        if (els.length === 0) {
          requestAnimationFrame(initReveal);
          return;
        }
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
            } else {
              e.target.classList.remove('is-revealed');
            }
          });
        }, { threshold: 0.1 });
        els.forEach((el) => observer.observe(el));
      }
      initReveal();
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>

<style is:global>
  [data-filing-label-variant] {
    display: none;
  }

  html[data-filing-variant="default"] [data-filing-label-variant="default"],
  html[data-filing-variant="gamemac-cn"] [data-filing-label-variant="gamemac-cn"] {
    display: inline;
  }
</style>
